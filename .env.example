# Database Configuration
# Supabase PostgreSQL database URL (with pgvector support)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# AI Configuration
FACE_RECOGNITION_MODEL_NAME=buffalo_l
SIMILARITY_THRESHOLD=0.60
DETECTION_THRESHOLD=0.5

# Tracking & Voting Configuration
TRACKING_BUFFER_FRAMES=30
TRACKING_THRESHOLD=0.5
TEMPORAL_VOTING_MIN_VOTES=4
TEMPORAL_VOTING_BUFFER_SIZE=7

# Camera Configuration
CAMERA_STARTUP_TIMEOUT_SEC=2.0

# General UI settings
APP_TITLE="AI Face Attendance System"
